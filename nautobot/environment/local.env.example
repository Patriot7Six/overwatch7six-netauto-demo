# Nautobot local environment settings — copy to local.env and customise
# DO NOT commit local.env to version control

# Nautobot version pins (change for upgrades)
NAUTOBOT_VERSION=3.1
PYTHON_VER=3.11

# Nautobot host/port exposed on the Docker host
NAUTOBOT_PORT=8080

# Redis connection (default matches docker-compose.yml)
REDIS_HOST=redis
REDIS_PORT=6379

# Database host (default matches docker-compose.yml service name)
DB_HOST=postgres
DB_PORT=5432
DB_NAME=nautobot
DB_USER=nautobot

# Nautobot-specific settings
NAUTOBOT_ALLOWED_HOSTS=*
NAUTOBOT_LOG_LEVEL=INFO
NAUTOBOT_METRICS_ENABLED=true

# Plugin configuration loaded via nautobot_config.py inside the container
# Installed apps are declared here so the container knows to enable them
NAUTOBOT_INSTALLED_APPS=nautobot_golden_config,nautobot_device_onboarding,nautobot_plugin_nornir

# The URL prefix for Golden Config's template and backup repositories
# In this demo both are local filesystem paths mounted into the container
GOLDEN_CONFIG_TEMPLATE_PATH=/opt/nautobot/golden_config/templates
GOLDEN_CONFIG_BACKUP_PATH=/opt/nautobot/golden_config/backups
