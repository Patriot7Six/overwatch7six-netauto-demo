# Nautobot local environment settings — copy to local.env and customise
# DO NOT commit local.env to version control
#
# Variable names confirmed against nautobot/core/settings.py and
# nautobot/core/settings_funcs.py (v3.1.x)

# Image version pins (used for Docker image tag substitution in docker-compose.yml)
NAUTOBOT_VERSION=3.1
PYTHON_VER=3.11

# Port exposed on the Docker host
NAUTOBOT_PORT=8080

# Redis — NAUTOBOT_REDIS_HOST/PORT read by nautobot/core/settings_funcs.py
NAUTOBOT_REDIS_HOST=redis
NAUTOBOT_REDIS_PORT=6379

# Database host/port — NAUTOBOT_DB_HOST/PORT read by nautobot/core/settings.py
# Name/user/password live in creds.env
NAUTOBOT_DB_HOST=postgres
NAUTOBOT_DB_PORT=5432

# Application settings
NAUTOBOT_ALLOWED_HOSTS=*
NAUTOBOT_LOG_LEVEL=INFO
NAUTOBOT_METRICS_ENABLED=true
