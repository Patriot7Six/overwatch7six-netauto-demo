# Nautobot credentials — copy to creds.env and fill in real values
# DO NOT commit creds.env to version control
#
# NAUTOBOT_DB_* vars  → read by Nautobot/worker/beat containers (nautobot_config.py)
# POSTGRES_*  vars    → read by the postgres container itself (official postgres image)
# These two sets must stay in sync if you change the password.

NAUTOBOT_DB_NAME=nautobot
NAUTOBOT_DB_USER=nautobot
NAUTOBOT_DB_PASSWORD=nautobot

POSTGRES_DB=nautobot
POSTGRES_USER=nautobot
POSTGRES_PASSWORD=nautobot

# Django secret key — generate a real one for any non-demo use:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
NAUTOBOT_SECRET_KEY=demo-secret-key-change-me-in-production

# Nautobot superuser created on first boot
# Confirmed var names from nautobot/docker/docker-entrypoint.sh v3.1.x
NAUTOBOT_CREATE_SUPERUSER=true
NAUTOBOT_SUPERUSER_NAME=admin
NAUTOBOT_SUPERUSER_EMAIL=admin@example.com
NAUTOBOT_SUPERUSER_PASSWORD=admin
NAUTOBOT_SUPERUSER_API_TOKEN=aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
